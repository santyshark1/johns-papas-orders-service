# FastAPI
APP_NAME=Pedidos Service
DEBUG=True
API_PREFIX=/api

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/johns_papas_db

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# External Services (Otros microservicios)
CUSTOMERS_SERVICE_URL=http://customers-service:8001
INVENTORY_SERVICE_URL=http://inventory-service:8002
PAYMENTS_SERVICE_URL=http://payments-service:8003
SHIPPING_SERVICE_URL=http://shipping-service:8004

# Logging
LOG_LEVEL=INFO

